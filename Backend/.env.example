# Smart Scheduling System - Environment Configuration
# Copy this file to .env and configure for your setup
# Fully Dockerized Setup

# Application
APP_ENV=dev
APP_SECRET=change-this-to-random-secret-key

# Database Configuration
MYSQL_ROOT_PASSWORD=your-root-password
MYSQL_DATABASE=smart_scheduling
MYSQL_USER=symfony
MYSQL_PASSWORD=your-password
MYSQL_PORT=3306

# Database Connection URL (Docker)
#DATABASE_URL=mysql://symfony:your-password@db:3306/smart_scheduling?serverVersion=8.0.31

# Application Port (Docker only)
APP_PORT=8000

# phpMyAdmin Port (Docker only, optional)
PHPMYADMIN_PORT=8080

# Mailer (configure based on your email service)
MAILER_DSN=null://null

# Default URI
DEFAULT_URI=http://localhost:8000

# Messenger
MESSENGER_TRANSPORT_DSN=doctrine://default

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change-this-to-a-random-passphrase
###< lexik/jwt-authentication-bundle ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###
