<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register - Smart Scheduling System</title>
    <link rel="icon" type="image/svg+xml" href="{{ asset('images/norsu-logo.svg') }}">

    <!-- Tailwind CSS -->
    <link href="/build/app.css" rel="stylesheet">

    {{ importmap('app') }}

    <style>
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-fade-in-up { animation: fadeInUp 0.6s ease-out; }

        .form-input {
            @apply appearance-none block w-full px-4 py-3 rounded-lg font-medium bg-gray-100 border border-gray-200 placeholder-gray-500 text-sm focus:outline-none focus:border-blue-400 focus:bg-white transition-all duration-200 ease-in-out;
        }
        .form-input:focus {
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.15);
        }
        .form-label {
            @apply block text-sm font-semibold text-gray-700 mb-1.5;
        }
        /* Error message styling */
        .invalid-feedback {
            @apply text-red-600 text-sm font-medium mt-1 block;
        }
        .invalid-feedback ul {
            @apply list-none p-0 m-0;
        }
        .invalid-feedback li {
            @apply flex items-start mt-1;
        }
        .invalid-feedback li:before {
            content: "⚠ ";
            @apply text-red-500 mr-1 font-bold;
        }
        .form-input.is-invalid {
            @apply border-red-500 focus:border-red-500;
            box-shadow: 0 0 0 3px rgba(248, 113, 113, 0.15);
        }
    </style>
</head>
<body class="h-full bg-gray-100 text-gray-900">
    <div class="min-h-screen flex justify-center items-center p-4 sm:p-10">
        <div class="max-w-screen-xl w-full bg-white shadow-xl sm:rounded-2xl flex justify-center flex-1 overflow-hidden animate-fade-in-up">
            <!-- Left Side - Branding Panel -->
            <div class="flex-1 bg-blue-50 text-center hidden lg:flex lg:max-w-sm xl:max-w-md">
                <div class="m-8 xl:m-12 w-full flex flex-col items-center justify-center">
                    <img src="{{ asset('images/norsu-logo.svg') }}" alt="NORSU Logo" class="w-28 h-28 mb-6 opacity-90">
                    <h2 class="text-2xl font-bold text-gray-800 mb-2">Join Our Community</h2>
                    <p class="text-base font-medium text-blue-700 mb-4">Smart Scheduling System</p>
                    <p class="text-gray-600 max-w-xs text-center leading-relaxed text-sm">
                        Create your faculty account to access intelligent scheduling, resource management, and academic tools.
                    </p>

                    <!-- Info card -->
                    <div class="mt-8 bg-white/70 rounded-xl p-5 max-w-xs w-full text-left">
                        <h4 class="text-sm font-semibold text-gray-800 mb-3">What you'll get:</h4>
                        <div class="space-y-2 text-sm text-gray-600">
                            <div class="flex items-center">
                                <svg class="w-4 h-4 text-blue-500 mr-2 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                                Secure account creation
                            </div>
                            <div class="flex items-center">
                                <svg class="w-4 h-4 text-blue-500 mr-2 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                                College & department association
                            </div>
                            <div class="flex items-center">
                                <svg class="w-4 h-4 text-blue-500 mr-2 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                                Immediate access after registration
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Side - Registration Form -->
            <div class="w-full lg:flex-1 p-6 sm:p-10 xl:p-12">
                <!-- Logo (mobile only) -->
                <div class="flex items-center justify-center lg:hidden mb-6">
                    <img src="{{ asset('images/norsu-logo.svg') }}" alt="NORSU Logo" class="w-12 h-12 mr-3">
                    <div>
                        <h1 class="text-xl font-bold text-gray-800">Smart Scheduling</h1>
                        <p class="text-xs text-gray-500">Academic Management System</p>
                    </div>
                </div>

                <div class="flex flex-col items-center">
                    <h2 class="text-2xl font-bold text-gray-800">Create Faculty Account</h2>
                    <p class="text-sm text-gray-500 mt-1">Fill in the details below to get started</p>
                    <p class="mt-2 text-sm text-gray-500">
                        Already have an account?
                        <a href="{{ path('app_login') }}" class="font-semibold text-blue-600 hover:text-blue-500 transition duration-200">
                            Sign in here
                        </a>
                    </p>

                    <!-- Divider -->
                    <div class="w-full my-6 border-b text-center">
                        <div class="leading-none px-2 inline-block text-sm text-gray-500 tracking-wide font-medium bg-white transform translate-y-1/2">
                            Account Information
                        </div>
                    </div>

                    <div class="w-full">
                        {{ form_start(registrationForm, {'attr': {'class': 'space-y-4'}}) }}
                            {# Name fields in 3 columns #}
                            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                                <div>
                                    {{ form_label(registrationForm.firstName, null, {'label_attr': {'class': 'form-label'}}) }}
                                    {{ form_widget(registrationForm.firstName, {'attr': {'class': 'form-input', 'placeholder': 'First name'}}) }}
                                    <div class="text-red-600 text-sm font-semibold mt-1">{{ form_errors(registrationForm.firstName) }}</div>
                                </div>

                                <div>
                                    {{ form_label(registrationForm.middleName, null, {'label_attr': {'class': 'form-label'}}) }}
                                    {{ form_widget(registrationForm.middleName, {'attr': {'class': 'form-input', 'placeholder': 'Middle name (optional)'}}) }}
                                    <div class="text-red-600 text-sm font-semibold mt-1">{{ form_errors(registrationForm.middleName) }}</div>
                                </div>

                                <div>
                                    {{ form_label(registrationForm.lastName, null, {'label_attr': {'class': 'form-label'}}) }}
                                    {{ form_widget(registrationForm.lastName, {'attr': {'class': 'form-input', 'placeholder': 'Last name'}}) }}
                                    <div class="text-red-600 text-sm font-semibold mt-1">{{ form_errors(registrationForm.lastName) }}</div>
                                </div>
                            </div>

                            {# Username and Employee ID in 2 columns #}
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                <div>
                                    {{ form_label(registrationForm.username, null, {'label_attr': {'class': 'form-label'}}) }}
                                    {{ form_widget(registrationForm.username, {'attr': {'class': 'form-input', 'placeholder': 'Choose a username'}}) }}
                                    <div class="text-red-600 text-sm font-semibold mt-1">{{ form_errors(registrationForm.username) }}</div>
                                </div>

                                <div>
                                    {{ form_label(registrationForm.employeeId, null, {'label_attr': {'class': 'form-label'}}) }}
                                    {{ form_widget(registrationForm.employeeId, {'attr': {'class': 'form-input', 'placeholder': 'Enter employee ID'}}) }}
                                    <div class="text-red-600 text-sm font-semibold mt-1">{{ form_errors(registrationForm.employeeId) }}</div>
                                </div>
                            </div>

                            {# Email and Address in 2 columns #}
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                <div>
                                    {{ form_label(registrationForm.email, null, {'label_attr': {'class': 'form-label'}}) }}
                                    {{ form_widget(registrationForm.email, {'attr': {'class': 'form-input', 'placeholder': 'Enter email address'}}) }}
                                    <div class="text-red-600 text-sm font-semibold mt-1">{{ form_errors(registrationForm.email) }}</div>
                                </div>

                                <div>
                                    {{ form_label(registrationForm.address, null, {'label_attr': {'class': 'form-label'}}) }}
                                    {{ form_widget(registrationForm.address, {'attr': {'class': 'form-input', 'placeholder': 'Enter address'}}) }}
                                    <div class="text-red-600 text-sm font-semibold mt-1">{{ form_errors(registrationForm.address) }}</div>
                                </div>
                            </div>

                            {# College and Department in 2 columns #}
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                <div>
                                    {{ form_label(registrationForm.college, null, {'label_attr': {'class': 'form-label'}}) }}
                                    {{ form_widget(registrationForm.college, {'attr': {'class': 'form-input', 'id': 'registration_form_college'}}) }}
                                    <div class="text-red-600 text-sm font-semibold mt-1">{{ form_errors(registrationForm.college) }}</div>
                                </div>

                                <div>
                                    {{ form_label(registrationForm.department, null, {'label_attr': {'class': 'form-label'}}) }}
                                    {{ form_widget(registrationForm.department, {'attr': {'class': 'form-input', 'id': 'registration_form_department'}}) }}
                                    <div class="text-red-600 text-sm font-semibold mt-1">{{ form_errors(registrationForm.department) }}</div>
                                </div>
                            </div>

                            {# Password fields in 2 columns #}
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                <div>
                                    {{ form_label(registrationForm.plainPassword.first, 'Password', {'label_attr': {'class': 'form-label'}}) }}
                                    {{ form_widget(registrationForm.plainPassword.first, {'attr': {'class': 'form-input', 'placeholder': 'Create a strong password'}}) }}
                                    <div class="text-red-600 text-sm font-semibold mt-1">{{ form_errors(registrationForm.plainPassword.first) }}</div>
                                </div>

                                <div>
                                    {{ form_label(registrationForm.plainPassword.second, 'Confirm Password', {'label_attr': {'class': 'form-label'}}) }}
                                    {{ form_widget(registrationForm.plainPassword.second, {'attr': {'class': 'form-input', 'placeholder': 'Confirm your password'}}) }}
                                    <div class="text-red-600 text-sm font-semibold mt-1">{{ form_errors(registrationForm.plainPassword.second) }}</div>
                                </div>
                            </div>

                            <div class="pt-2">
                                <button type="submit" class="tracking-wide font-semibold bg-blue-500 text-white w-full py-4 rounded-lg hover:bg-blue-600 transition-all duration-300 ease-in-out flex items-center justify-center focus:shadow-outline focus:outline-none">
                                    <svg class="w-6 h-6 -ml-2" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                                        <path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" />
                                        <circle cx="8.5" cy="7" r="4" />
                                        <path d="M20 8v6M23 11h-6" />
                                    </svg>
                                    <span class="ml-3">Create Faculty Account</span>
                                </button>
                            </div>

                            {{ form_rest(registrationForm) }}
                        {{ form_end(registrationForm) }}

                        <p class="mt-6 text-xs text-gray-500 text-center">
                            Your account will be created with <span class="font-semibold">Faculty role</span> by default.
                            After registration, you can access your personal dashboard and start managing your schedule.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // ==========================================
            // REAL-TIME FORM VALIDATION
            // ==========================================
            const formFields = {
                firstName: document.querySelector('#registration_form_firstName'),
                lastName: document.querySelector('#registration_form_lastName'),
                username: document.querySelector('#registration_form_username'),
                employeeId: document.querySelector('#registration_form_employeeId'),
                email: document.querySelector('#registration_form_email'),
                password: document.querySelector('#registration_form_plainPassword_first'),
                confirmPassword: document.querySelector('#registration_form_plainPassword_second'),
            };

            // --- Utility: show/clear field errors ---
            function showFieldError(field, message) {
                if (!field) return;
                field.classList.add('is-invalid');
                field.style.borderColor = '#ef4444';
                field.style.backgroundColor = '#fef2f2';
                clearFieldFeedback(field);
                const fb = document.createElement('div');
                fb.className = 'field-feedback text-sm mt-1 flex items-center text-red-600';
                fb.innerHTML = '<svg class="w-4 h-4 mr-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/></svg>' + message;
                field.parentNode.appendChild(fb);
            }

            function showFieldSuccess(field, message) {
                if (!field) return;
                field.classList.remove('is-invalid');
                field.style.borderColor = '#22c55e';
                field.style.backgroundColor = '#f0fdf4';
                clearFieldFeedback(field);
                if (message) {
                    const fb = document.createElement('div');
                    fb.className = 'field-feedback text-sm mt-1 flex items-center text-green-600';
                    fb.innerHTML = '<svg class="w-4 h-4 mr-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>' + message;
                    field.parentNode.appendChild(fb);
                }
            }

            function clearFieldState(field) {
                if (!field) return;
                field.classList.remove('is-invalid');
                field.style.borderColor = '';
                field.style.backgroundColor = '';
                clearFieldFeedback(field);
            }

            function clearFieldFeedback(field) {
                if (!field) return;
                const existing = field.parentNode.querySelectorAll('.field-feedback');
                existing.forEach(el => el.remove());
            }

            // --- Validation rules ---
            function validateFirstName(val) {
                if (!val || val.trim().length === 0) return 'Please enter your first name';
                if (val.trim().length < 2) return 'First name must be at least 2 characters';
                if (val.trim().length > 100) return 'First name cannot exceed 100 characters';
                return null;
            }

            function validateLastName(val) {
                if (!val || val.trim().length === 0) return 'Please enter your last name';
                if (val.trim().length < 2) return 'Last name must be at least 2 characters';
                if (val.trim().length > 100) return 'Last name cannot exceed 100 characters';
                return null;
            }

            function validateUsername(val) {
                if (!val || val.trim().length === 0) return 'Please choose a username';
                if (val.trim().length < 3) return 'Username must be at least 3 characters';
                if (val.trim().length > 100) return 'Username cannot exceed 100 characters';
                return null;
            }

            function validateEmployeeId(val) {
                if (!val || val.trim().length === 0) return 'Please enter your employee ID';
                if (val.trim().length < 6) return 'Employee ID must be at least 6 characters';
                if (val.trim().length > 15) return 'Employee ID cannot exceed 15 characters';
                return null;
            }

            function validateEmail(val) {
                if (!val || val.trim().length === 0) return 'Please enter your email address';
                const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
                if (!emailRegex.test(val.trim())) return 'Please enter a valid email address';
                return null;
            }

            function validatePassword(val) {
                if (!val || val.length === 0) return 'Please enter a password';
                if (val.length < 6) return 'Password must be at least 6 characters';
                return null;
            }

            function validateConfirmPassword(val) {
                if (!formFields.password) return null;
                const pw = formFields.password.value;
                if (!val || val.length === 0) return 'Please confirm your password';
                if (val !== pw) return 'Passwords do not match';
                return null;
            }

            // --- AJAX uniqueness check ---
            let checkTimeouts = {};
            function checkAvailability(fieldName, value, element) {
                // Map to API field names
                const apiField = fieldName === 'employeeId' ? 'employee_id' : fieldName;
                
                // Add loading indicator
                element.style.borderColor = '#60a5fa';
                clearFieldFeedback(element);
                const loadingFb = document.createElement('div');
                loadingFb.className = 'field-feedback text-sm mt-1 flex items-center text-blue-500';
                loadingFb.innerHTML = '<svg class="animate-spin w-4 h-4 mr-1" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>Checking availability...';
                element.parentNode.appendChild(loadingFb);

                fetch('{{ path("app_register_check_availability") }}', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: JSON.stringify({ field: apiField, value: value })
                })
                .then(r => {
                    if (!r.ok) throw new Error('Server error');
                    const contentType = r.headers.get('content-type');
                    if (!contentType || !contentType.includes('application/json')) {
                        throw new Error('Not JSON response');
                    }
                    return r.json();
                })
                .then(data => {
                    if (data.available) {
                        showFieldSuccess(element, 'Available');
                    } else {
                        showFieldError(element, data.message || 'Already taken');
                    }
                })
                .catch((err) => {
                    console.error('Availability check failed:', err);
                    clearFieldState(element);
                });
            }

            // --- Attach blur validators ---
            const fieldValidators = [
                { field: formFields.firstName, validate: validateFirstName },
                { field: formFields.lastName,  validate: validateLastName },
                { field: formFields.username,  validate: validateUsername, checkUnique: 'username' },
                { field: formFields.employeeId, validate: validateEmployeeId, checkUnique: 'employeeId' },
                { field: formFields.email,     validate: validateEmail, checkUnique: 'email' },
                { field: formFields.password,  validate: validatePassword },
                { field: formFields.confirmPassword, validate: validateConfirmPassword },
            ];

            fieldValidators.forEach(({ field, validate, checkUnique }) => {
                if (!field) return;

                // Validate on blur
                field.addEventListener('blur', function() {
                    const error = validate(this.value);
                    if (error) {
                        showFieldError(this, error);
                    } else if (checkUnique) {
                        // Client-side OK — now check server uniqueness
                        checkAvailability(checkUnique, this.value, this);
                    } else {
                        showFieldSuccess(this, null);
                    }
                });

                // Clear errors on input (debounced)
                field.addEventListener('input', function() {
                    clearFieldState(this);
                    // For confirm password, also re-validate 
                    if (this === formFields.password && formFields.confirmPassword && formFields.confirmPassword.value) {
                        const cpError = validateConfirmPassword(formFields.confirmPassword.value);
                        if (cpError) {
                            showFieldError(formFields.confirmPassword, cpError);
                        } else {
                            showFieldSuccess(formFields.confirmPassword, null);
                        }
                    }
                });

                // Focus: reset style
                field.addEventListener('focus', function() {
                    this.style.borderColor = '';
                    this.style.backgroundColor = '';
                });
            });

            // --- Password strength meter ---
            if (formFields.password) {
                const strengthContainer = document.createElement('div');
                strengthContainer.className = 'field-feedback mt-2';
                strengthContainer.innerHTML = `
                    <div class="flex items-center gap-1 mb-1">
                        <div class="h-1.5 flex-1 rounded-full bg-gray-200 overflow-hidden"><div id="pw-str-1" class="h-full rounded-full transition-all duration-300" style="width:0"></div></div>
                        <div class="h-1.5 flex-1 rounded-full bg-gray-200 overflow-hidden"><div id="pw-str-2" class="h-full rounded-full transition-all duration-300" style="width:0"></div></div>
                        <div class="h-1.5 flex-1 rounded-full bg-gray-200 overflow-hidden"><div id="pw-str-3" class="h-full rounded-full transition-all duration-300" style="width:0"></div></div>
                        <div class="h-1.5 flex-1 rounded-full bg-gray-200 overflow-hidden"><div id="pw-str-4" class="h-full rounded-full transition-all duration-300" style="width:0"></div></div>
                    </div>
                    <p id="pw-str-text" class="text-xs text-gray-500"></p>
                `;
                formFields.password.parentNode.appendChild(strengthContainer);

                formFields.password.addEventListener('input', function() {
                    updatePasswordStrength(this.value);
                });
            }

            function updatePasswordStrength(password) {
                let score = 0;
                if (password.length >= 6) score++;
                if (password.length >= 10) score++;
                if (/[A-Z]/.test(password) && /[a-z]/.test(password)) score++;
                if (/[0-9]/.test(password)) score++;
                if (/[^A-Za-z0-9]/.test(password)) score++;
                score = Math.min(score, 4);

                const colors = ['#ef4444', '#f97316', '#eab308', '#22c55e'];
                const labels = ['Weak', 'Fair', 'Good', 'Strong'];

                for (let i = 1; i <= 4; i++) {
                    const bar = document.getElementById('pw-str-' + i);
                    if (bar) {
                        bar.style.width = (i <= score) ? '100%' : '0';
                        bar.style.backgroundColor = (i <= score) ? colors[Math.min(score, 4) - 1] : '';
                    }
                }
                const text = document.getElementById('pw-str-text');
                if (text) {
                    if (password.length === 0) {
                        text.textContent = '';
                    } else {
                        text.textContent = labels[Math.min(score, 4) - 1] || 'Too short';
                        text.style.color = colors[Math.min(score, 4) - 1] || '#ef4444';
                    }
                }
            }

            // --- Form submit validation ---
            const regForm = document.querySelector('form');
            if (regForm) {
                let isSubmitting = false;
                regForm.addEventListener('submit', function(e) {
                    if (isSubmitting) { e.preventDefault(); return; }

                    let firstErrorField = null;
                    fieldValidators.forEach(({ field, validate }) => {
                        if (!field) return;
                        const error = validate(field.value);
                        if (error) {
                            showFieldError(field, error);
                            if (!firstErrorField) firstErrorField = field;
                        }
                    });

                    // Also check college & department
                    const collegeField = document.querySelector('#registration_form_college');
                    const deptField = document.querySelector('#registration_form_department');
                    if (collegeField && !collegeField.value) {
                        showFieldError(collegeField, 'Please select your college');
                        if (!firstErrorField) firstErrorField = collegeField;
                    }
                    if (deptField && !deptField.value) {
                        showFieldError(deptField, 'Please select your department');
                        if (!firstErrorField) firstErrorField = deptField;
                    }

                    // Check for any existing is-invalid fields
                    const hasServerErrors = regForm.querySelectorAll('.is-invalid').length > 0;

                    if (firstErrorField || hasServerErrors) {
                        e.preventDefault();
                        if (firstErrorField) {
                            firstErrorField.scrollIntoView({ behavior: 'smooth', block: 'center' });
                            firstErrorField.focus();
                        }
                        return;
                    }

                    // Show loading state
                    isSubmitting = true;
                    const submitBtn = regForm.querySelector('button[type="submit"]');
                    if (submitBtn) {
                        submitBtn.disabled = true;
                        const btnText = submitBtn.querySelector('span');
                        if (btnText) btnText.textContent = 'Creating Account...';
                        // Add spinner
                        const spinner = document.createElement('svg');
                        spinner.className = 'animate-spin h-5 w-5 ml-2';
                        spinner.setAttribute('viewBox', '0 0 24 24');
                        spinner.setAttribute('fill', 'none');
                        spinner.innerHTML = '<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>';
                        submitBtn.appendChild(spinner);
                    }
                });
            }

            // ==========================================
            // COLLEGE-DEPARTMENT FILTERING (existing)
            // ==========================================
            console.log('Registration form college-department filtering loaded');
            
            // Get the departments data from PHP
            const departmentsByCollege = {{ departments_by_college|json_encode|raw }};
            console.log('Departments by college data:', departmentsByCollege);
            console.log('Department data keys (College IDs):', Object.keys(departmentsByCollege));
            
            // Log each college's departments
            Object.keys(departmentsByCollege).forEach(collegeId => {
                console.log(`College ID ${collegeId}:`, departmentsByCollege[collegeId]);
            });
            
            // Multiple strategies to find form elements
            function findElement(selectors) {
                for (let selector of selectors) {
                    const element = document.querySelector(selector);
                    if (element) {
                        console.log('Found element with selector:', selector);
                        return element;
                    }
                }
                return null;
            }
            
            // Try multiple selectors for college field
            const collegeSelectors = [
                '#registration_form_college',
                'select[name="registration_form[college]"]',
                'select[id*="college"]',
                'select[name*="college"]',
                '.college-select'
            ];
            
            // Try multiple selectors for department field
            const departmentSelectors = [
                '#registration_form_department',
                'select[name="registration_form[department]"]',
                'select[id*="department"]',
                'select[name*="department"]',
                '.department-select'
            ];
            
            const collegeSelect = findElement(collegeSelectors);
            const departmentSelect = findElement(departmentSelectors);
            
            console.log('College select element:', collegeSelect);
            console.log('Department select element:', departmentSelect);
            
            if (collegeSelect && departmentSelect) {
                console.log('Both elements found, setting up event listener');
                
                // Store original options for department select
                const originalDepartmentOptions = Array.from(departmentSelect.options);
                console.log('Original department options:', originalDepartmentOptions.length);
                
                // Function to populate departments based on selected college
                function populateDepartments(collegeId) {
                    console.log('Populating departments for college ID:', collegeId);
                    
                    // Clear existing options
                    departmentSelect.innerHTML = '';
                    
                    // Add placeholder option
                    const placeholderOption = document.createElement('option');
                    placeholderOption.value = '';
                    placeholderOption.textContent = 'Select your department';
                    departmentSelect.appendChild(placeholderOption);
                    
                    // Convert collegeId to number to match the object keys
                    const numericCollegeId = parseInt(collegeId, 10);
                    console.log('Converted college ID to number:', numericCollegeId);
                    
                    // Try both string and numeric versions
                    const departments = departmentsByCollege[collegeId] || departmentsByCollege[numericCollegeId];
                    
                    if (departments && departments.length > 0) {
                        console.log('Found departments for college:', departments);
                        
                        // Sort departments by name before adding
                        const sortedDepartments = departments.sort((a, b) => {
                            return a.name.localeCompare(b.name);
                        });
                        
                        sortedDepartments.forEach(function(department) {
                            const option = document.createElement('option');
                            option.value = department.id;
                            option.textContent = department.name;
                            departmentSelect.appendChild(option);
                        });
                        
                        departmentSelect.disabled = false;
                        departmentSelect.style.opacity = '1';
                        console.log(`${sortedDepartments.length} departments populated, select enabled`);
                    } else {
                        console.log('No college selected or no departments found, disabling select');
                        departmentSelect.disabled = true;
                        departmentSelect.style.opacity = '0.5';
                    }
                }
                
                // Set up event listener with error handling
                collegeSelect.addEventListener('change', function() {
                    try {
                        const selectedCollegeId = this.value;
                        console.log('College changed to:', selectedCollegeId);
                        console.log('Type of selected college ID:', typeof selectedCollegeId);
                        console.log('Available college IDs in data:', Object.keys(departmentsByCollege));
                        console.log('Does exact match exist?', departmentsByCollege.hasOwnProperty(selectedCollegeId));
                        populateDepartments(selectedCollegeId);
                    } catch (error) {
                        console.error('Error in college change handler:', error);
                    }
                });
                
                // Initial setup
                departmentSelect.disabled = true;
                departmentSelect.style.opacity = '0.5';
                
                // Initial population if a college is already selected
                if (collegeSelect.value) {
                    console.log('Initial college value:', collegeSelect.value);
                    populateDepartments(collegeSelect.value);
                } else {
                    console.log('No initial college value, department select disabled');
                }
                
                // Add visual feedback
                collegeSelect.addEventListener('focus', function() {
                    this.style.borderColor = '#60a5fa';
                });
                
                collegeSelect.addEventListener('blur', function() {
                    this.style.borderColor = '#e5e7eb';
                });
                
            } else {
                console.error('Could not find college or department select elements');
                console.log('Available select elements:');
                document.querySelectorAll('select').forEach((select, index) => {
                    console.log(`Select ${index}:`, {
                        id: select.id,
                        name: select.name,
                        className: select.className
                    });
                });
            }
        });
    </script>
</body>
</html>